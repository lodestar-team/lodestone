services:
  postgres:
    image: postgres:16-alpine
    environment:
      POSTGRES_USER:     {{service_slug}}
      POSTGRES_PASSWORD: {{service_slug}}
      POSTGRES_DB:       {{service_slug}}_gateway
    ports:
      - "5432:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{service_slug}}"]
      interval: 5s
      timeout: 3s
      retries: 10

  # Query/serve layer over the indexed data. Point the gateway's upstream_url here.
  postgrest:
    image: postgrest/postgrest:v12.2.3
    depends_on:
      postgres:
        condition: service_healthy
    environment:
      PGRST_DB_URI: postgres://{{service_slug}}:{{service_slug}}@postgres:5432/{{service_slug}}_gateway
      PGRST_DB_ANON_ROLE: {{service_slug}}
    ports:
      - "3000:3000"

  {{service_slug}}-gateway:
    build:
      context: .
      target: gateway
    depends_on:
      postgres:
        condition: service_healthy
    environment:
      GATEWAY_CONFIG: /app/config.toml
      RUST_LOG:       {{service_slug}}_gateway=info,horizon_core=info
    volumes:
      - ./gateway.toml:/app/config.toml:ro
    ports:
      - "{{default_port}}:{{default_port}}"

  # The indexer runs the Substrate -> Handler -> Sink pipeline. By default it uses a mock
  # substrate + stdout sink; wire a real substrate and a Postgres sink, then enable here.
  {{service_slug}}-indexer:
    build:
      context: .
      target: indexer
    depends_on:
      postgres:
        condition: service_healthy
    environment:
      RUST_LOG: {{service_slug}}_indexer=info
    profiles: ["indexer"]

volumes:
  pgdata:
