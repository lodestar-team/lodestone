//! {{service_title}} gateway — Horizon TAP v2 (GraphTally) payment layer in front of the
//! query/serve layer over the indexed data (e.g. PostgREST on the sink's Postgres).
//!
//! All payment machinery lives in `horizon-core`. A consumer sends a signed `TAP-Receipt`
//! header; the gateway verifies + meters it and proxies the request to `backend.upstream_url`.

use horizon_core::Config;

#[tokio::main]
async fn main() -> anyhow::Result<()> {
    dotenvy::dotenv().ok();

    tracing_subscriber::fmt()
        .with_env_filter(
            tracing_subscriber::EnvFilter::try_from_default_env()
                .unwrap_or_else(|_| "{{service_slug}}_gateway=info,horizon_core=info".into()),
        )
        .init();

    let config = Config::load()?;
    tracing::info!(
        upstream = %config.backend.upstream_url,
        data_service = %config.tap.data_service_address,
        "{{service_title}} gateway starting"
    );

    horizon_core::run(config).await
}
